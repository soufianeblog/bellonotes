#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Machine-specific SDK paths (regenerated by Flutter on each machine)
/android/local.properties
**/android/local.properties
.flutter-plugins

# Per-platform generated/ephemeral files
**/Flutter/ephemeral/
**/flutter/ephemeral/
/android/.gradle/
/android/captures/
/ios/Flutter/flutter_export_environment.sh
/macos/Flutter/ephemeral/
/windows/flutter/ephemeral/
/linux/flutter/ephemeral/

# Signing material & secrets — never commit these to the public repo
*.keystore
*.jks
**/key.properties
**/google-services.json
**/GoogleService-Info.plist
*.p12
*.pem
.env
.env.*

